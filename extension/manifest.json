{
  "manifest_version": 3,
  "name": "Samurai Operations Assistant",
  "short_name": "SOA",
  "version": "0.4.1",
  "description": "Operations assistant for Samurai Branch Tracking",

  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles/dashboard.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  }
}